meta {
  name: Update Contact
  type: http
  seq: 5
}

patch {
  url: {{base_url}}/contacts/:id
  body: json
  auth: none
}

params:path {
  id: CONTACT_ID
}

headers {
  Authorization: Bearer {{access_token}}
  Content-Type: application/json
}

body:json {
  {
    "phone": "+52 55 0000 1111",
    "notes": "Actualizado"
  }
}
