meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: http://127.0.0.1:54321/auth/v1/token?grant_type=password
  body: json
  auth: none
}

headers {
  apikey: {{anon_key}}
  Content-Type: application/json
}

body:json {
  {
    "email": "test1@jacatsoft.com",
    "password": "123456"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("access_token", res.body.access_token);
  }
}
